<?xml version="1.0" encoding="utf-8"?>
<!--
    BLE Lab Explorer — nRF Connect GATT Server Configuration
    =========================================================
    Import this file in nRF Connect for Mobile (Android):
      1. Open nRF Connect → Menu → Configure GATT Server
      2. Tap the Import icon (top right)
      3. Select this file
      4. Tap "Advertise" to start broadcasting

    This creates the same 3 services exposed by the in-browser
    Simulation Mode, so students can use their smartphone as a
    real BLE peripheral and connect to it with the lab web app.

    SERVICES
    ─────────────────────────────────────────────────────────
    Battery Service       (0x180F)  battery_level  READ + NOTIFY
    Environmental Sensing (0x181A)  temperature    READ + NOTIFY
    Lab Custom Service    (0xFFFF)  lab_rw         READ + WRITE
                                    lab_counter    READ + NOTIFY
-->
<server>

    <!-- ══════════════════════════════════════════════════════
         Service 1 — Battery Service (Bluetooth SIG 0x180F)
         ══════════════════════════════════════════════════════ -->
    <service uuid="0000180f-0000-1000-8000-00805f9b34fb"
             name="Battery Service"
             type="primary">

        <!--
            Battery Level Characteristic (0x2A19)
            Properties : READ, NOTIFY
            Value       : 0x57 = 87 (decimal) = 87% battery
        -->
        <characteristic uuid="00002a19-0000-1000-8000-00805f9b34fb"
                         name="Battery Level">
            <properties read="true" notify="true" />
            <value length="1" type="hex">57</value>

            <!-- CCCD — required for notifications to work -->
            <descriptor uuid="00002902-0000-1000-8000-00805f9b34fb"
                        name="Client Characteristic Configuration">
                <properties read="true" write="true" />
                <value length="2" type="hex">0000</value>
            </descriptor>
        </characteristic>

    </service>

    <!-- ══════════════════════════════════════════════════════
         Service 2 — Environmental Sensing (Bluetooth SIG 0x181A)
         ══════════════════════════════════════════════════════ -->
    <service uuid="0000181a-0000-1000-8000-00805f9b34fb"
             name="Environmental Sensing"
             type="primary">

        <!--
            Temperature Characteristic (0x2A6E)
            Properties : READ, NOTIFY
            Value       : 0x8608 = 2150 (little-endian int16)
                          Unit = 0.01 °C → 2150 × 0.01 = 21.50 °C
        -->
        <characteristic uuid="00002a6e-0000-1000-8000-00805f9b34fb"
                         name="Temperature">
            <properties read="true" notify="true" />
            <value length="2" type="hex">8608</value>

            <!-- CCCD — required for notifications to work -->
            <descriptor uuid="00002902-0000-1000-8000-00805f9b34fb"
                        name="Client Characteristic Configuration">
                <properties read="true" write="true" />
                <value length="2" type="hex">0000</value>
            </descriptor>
        </characteristic>

    </service>

    <!-- ══════════════════════════════════════════════════════
         Service 3 — Lab Custom Service (0xFFFF)
         Custom service used for READ/WRITE and NOTIFY exercises.
         ══════════════════════════════════════════════════════ -->
    <service uuid="0000ffff-0000-1000-8000-00805f9b34fb"
             name="Lab Custom Service"
             type="primary">

        <!--
            Lab RW Characteristic (0xFF01)
            Properties : READ, WRITE, WRITE WITHOUT RESPONSE
            Value       : "hello" encoded as UTF-8 bytes
            Students can read its value and overwrite it.
        -->
        <characteristic uuid="0000ff01-0000-1000-8000-00805f9b34fb"
                         name="Lab RW">
            <properties read="true"
                         write="true"
                         writeWithoutResponse="true" />
            <value length="5" type="text">hello</value>
        </characteristic>

        <!--
            Lab Counter Characteristic (0xFF02)
            Properties : READ, NOTIFY
            Value       : 0x00 (starts at 0; increment manually in nRF Connect)
            Students subscribe and see new values pushed by the device.
        -->
        <characteristic uuid="0000ff02-0000-1000-8000-00805f9b34fb"
                         name="Lab Counter">
            <properties read="true" notify="true" />
            <value length="1" type="hex">00</value>

            <!-- CCCD — required for notifications to work -->
            <descriptor uuid="00002902-0000-1000-8000-00805f9b34fb"
                        name="Client Characteristic Configuration">
                <properties read="true" write="true" />
                <value length="2" type="hex">0000</value>
            </descriptor>
        </characteristic>

    </service>

</server>
